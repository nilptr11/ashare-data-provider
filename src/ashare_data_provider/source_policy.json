{
  "version": 1,
  "updated_at": "2026-06-22",
  "scope": "A-share research context source policy for Prism.",
  "principles": [
    "Prefer structured project data over ad hoc web search.",
    "Do not call Tushare interfaces that require separate permission.",
    "Use unknown-eligibility Tushare interfaces only after smoke verification or an existing successful local cache.",
    "Use official or exchange sources for regulatory, announcement, macro, and policy data.",
    "Use non-official finance websites as auxiliary sources unless no official source exists for that data type."
  ],
  "tushare": {
    "blocked_eligibility": ["needs_separate_permission"],
    "blocked_apis": {
      "news": {
        "reason": "requires separate permission",
        "replacement_source_groups": ["event_news", "finance_news"]
      },
      "research_report": {
        "reason": "requires separate permission",
        "replacement_source_groups": ["research_reports"]
      },
