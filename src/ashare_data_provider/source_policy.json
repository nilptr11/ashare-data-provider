    "preferred_apis": {
      "identity": ["stock_basic", "stock_company", "stock_hsgt", "stock_st", "st"],
      "calendar": ["trade_cal"],
      "market_daily": ["daily", "daily_basic", "adj_factor", "stk_limit", "pro_bar"],
      "market_weekly_monthly": ["weekly", "monthly", "stk_weekly_monthly", "stk_week_month_adj"],
      "index_and_industry": ["index_daily", "index_dailybasic", "sw_daily", "ci_daily", "index_member_all", "ci_index_member", "index_classify", "index_weight", "daily_info", "sz_daily_info"],
      "fundamentals": ["income", "balancesheet", "cashflow", "fina_indicator", "fina_mainbz", "express", "forecast", "dividend", "fina_audit", "disclosure_date"],
      "shareholders": ["top10_holders", "top10_floatholders", "stk_holdertrade", "pledge_stat", "pledge_detail", "share_float", "repurchase"],
      "margin_and_flow": ["margin_detail", "slb_len", "moneyflow_ind_ths", "moneyflow_ind_dc", "moneyflow_cnt_ths"],
      "themes_and_short_term": ["limit_list_d", "limit_list_ths", "limit_step", "limit_cpt_list", "top_list", "dc_daily", "ths_member", "tdx_member", "tdx_daily", "ths_hot", "kpl_list"],
      "macro": ["shibor", "shibor_quote", "cn_ppi", "cn_gdp", "sf_month", "us_trycr", "us_tltr", "hibor", "wz_index", "gz_index"],
      "events": ["eco_cal"]
    },
    "conditional_unknown_apis": {
      "allow_when": [
        "smoke_status == success",
        "local_cache has successful current data for exact params",
        "operator explicitly permits exploratory call"
      ],
      "examples": ["daily", "pro_bar", "trade_cal", "cn_cpi", "shibor_lpr", "cn_pmi", "cn_m", "moneyflow", "moneyflow_hsgt", "rt_k", "rt_min", "forecast"]
    }
  },
