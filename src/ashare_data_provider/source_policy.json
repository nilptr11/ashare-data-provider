  "dynamic_source_discovery": {
    "scope": "LLM-controlled discovery for industry-specific facts that cannot be covered by a universal A-share structured dataset.",
    "allowed_when": [
      "The fact is industry-specific, such as supply-demand, capacity, utilization, order backlog, tender data, commodity price, installed capacity, policy subsidy, technology standard, or customer concentration.",
      "Project structured data does not provide the fact, or only provides generic financial/market indicators.",
      "The final report clearly separates discovered facts from project-provider facts."
    ],
    "not_allowed_for": [
      "Replacing project price, valuation, financial statements, shareholder, pledge, repurchase, or official announcement facts when project data is available.",
      "Using generic finance media as the sole source for audited financial, regulatory, macro, or company-specific material facts.",
      "Inferring company orders, customers, capacity, or market share from industry news without company filings or a primary/official source."
    ],
    "source_classes": [
      {
        "id": "official_government_or_regulator",
        "trust_level": "official",
        "examples": ["gov.cn", "stats.gov.cn", "pbc.gov.cn", "ndrc.gov.cn", "miit.gov.cn", "mee.gov.cn", "nea.gov.cn", "csrc.gov.cn"],
        "use_for": ["policy", "macro", "industry regulation", "official statistical releases"]
      },
      {
        "id": "exchange_or_disclosure_platform",
        "trust_level": "official_or_official_aggregator",
        "examples": ["sse.com.cn", "szse.cn", "cninfo.com.cn"],
        "use_for": ["company filings", "periodic reports", "regulatory announcements"]
      },
      {
        "id": "listed_company_official",
        "trust_level": "company_primary",
        "examples": ["company official website", "company investor relations page", "company annual report PDF"],
        "use_for": ["company operations", "projects", "capacity", "customer disclosures", "business explanations"],
        "notes": "Company claims should be cross-checked with formal filings when material."
      },
      {
        "id": "industry_association_or_designated_publisher",
        "trust_level": "sector_primary_or_auxiliary",
        "examples": ["recognized industry associations", "officially designated market data publishers"],
        "use_for": ["industry supply-demand", "installed capacity", "production/sales data", "sector statistics"]
      },
      {
        "id": "commodity_exchange_or_index_provider",
        "trust_level": "market_data_auxiliary",
        "examples": ["commodity exchanges", "official price index publishers"],
        "use_for": ["commodity prices", "input cost trends", "sector price indexes"]
      },
      {
        "id": "reputable_finance_or_trade_media",
        "trust_level": "auxiliary",
        "examples": ["finance news", "trade press"],
        "use_for": ["event discovery", "cross-check leads"],
        "notes": "Cannot be the sole source for material facts."
      }
    ],
    "evidence_requirements": [
      "Record URL, source name, source_class id, query time, publish/update date when available, and the exact fact extracted.",
      "State why the source is relevant to the target company's industry or business segment.",
      "For every industry-specific conclusion, label it as project_data, official_external, company_external, association_external, or auxiliary_external.",
      "If no acceptable source is found, write 暂无可靠数据 instead of broadening to low-quality sources."
    ]
  },
  "gap_resolution": {
    "default": {
      "allowed_source_groups": [],
      "action": "mark_unavailable",
      "notes": "If no rule matches a data gap, do not freely search the web; mark it as 暂无可靠数据."
    },
    "rules": [
      {
        "id": "market_daily_gap",
        "match": {
          "section": "market",
          "api_names": ["daily", "daily_basic", "pro_bar", "adj_factor", "stk_limit", "rt_k", "rt_min"]
        },
        "allowed_source_groups": ["intraday_market"],
        "priority": ["user_screenshot", "eastmoney_quote"],
        "critical_use": "auxiliary_only",
        "notes": "For end-of-day facts prefer project data. External quotes are for live/intraday reference and must include query time."
      },
      {
        "id": "index_market_gap",
        "match": {
          "section": "macro",
          "api_names": ["index_daily", "index_dailybasic", "daily_info", "sz_daily_info", "index_global"]
        },
        "allowed_source_groups": ["industry_market", "intraday_market"],
        "priority": ["eastmoney_sector_quote", "eastmoney_quote"],
        "critical_use": "auxiliary_only",
        "notes": "Use for broad market or index fallback. Prefer project Tushare index data when available."
      },
      {
        "id": "industry_market_gap",
        "match": {
          "section": "industry",
          "api_names": ["sw_daily", "ci_daily", "dc_daily", "ths_daily", "index_member_all", "ci_index_member", "ths_member", "dc_member"]
        },
        "allowed_source_groups": ["industry_market"],
        "priority": ["eastmoney_sector_quote"],
        "critical_use": "auxiliary_only",
        "notes": "Use only for sector trend or membership clues; do not infer supply-demand facts from sector quotes."
      },
      {
        "id": "financial_statement_gap",
        "match": {
          "section": "fundamentals",
          "api_names": ["income", "balancesheet", "cashflow", "fina_indicator", "fina_mainbz", "express", "forecast", "dividend", "fina_audit", "disclosure_date"]
        },
        "allowed_source_groups": ["announcements"],
        "priority": ["cninfo_disclosure", "sse_announcements", "szse_announcements", "eastmoney_notices"],
        "critical_use": "official_required",
        "notes": "Financial statement facts must come from official exchange/CNINFO filings or project structured data."
      },
      {
        "id": "announcement_event_gap",
        "match": {
          "section": "events",
          "names": ["announcements", "earnings_forecast"],
          "api_names": ["anns_d", "forecast", "express"]
        },
        "allowed_source_groups": ["announcements"],
        "priority": ["cninfo_disclosure", "sse_announcements", "szse_announcements", "eastmoney_notices"],
        "critical_use": "official_required",
        "notes": "Use official filings for event facts; Eastmoney may be used for discovery and cross-check."
      },
      {
        "id": "macro_gap",
        "match": {
          "section": "macro",
          "api_names": ["cn_cpi", "cn_ppi", "cn_pmi", "cn_gdp", "sf_month", "cn_m", "shibor", "shibor_quote", "shibor_lpr", "us_tltr", "us_trycr", "us_tycr", "us_tbr"]
        },
        "allowed_source_groups": ["macro", "policy"],
        "priority": ["stats_national_data", "pbc_interest_rates", "shibor", "fred_dgs10", "gov_cn"],
        "critical_use": "official_required",
        "notes": "Macro values and policy statements require official or official-data-repository sources."
      },
      {
        "id": "moneyflow_gap",
        "match": {
          "section": "trading",
          "api_names": ["moneyflow", "moneyflow_hsgt", "moneyflow_ind_ths", "moneyflow_ind_dc", "moneyflow_mkt_dc", "moneyflow_ths", "moneyflow_dc", "moneyflow_cnt_ths"]
        },
        "allowed_source_groups": ["moneyflow"],
        "priority": ["eastmoney_moneyflow"],
        "critical_use": "auxiliary_only",
        "notes": "Money-flow data is secondary confirmation, not a sole basis for investment conclusions."
      },
      {
        "id": "margin_and_lhb_gap",
        "match": {
          "section": "trading",
          "api_names": ["margin", "margin_detail", "top_list", "top_inst", "limit_list_d", "limit_list_ths", "limit_step", "limit_cpt_list"]
        },
        "allowed_source_groups": ["moneyflow", "finance_news"],
        "priority": ["eastmoney_moneyflow", "eastmoney_kuaixun"],
        "critical_use": "auxiliary_only",
        "notes": "Use as short-term trading context only; do not present as fundamental verification."
      },
      {
        "id": "shareholder_gap",
        "match": {
          "section": "fundamentals",
          "api_names": ["top10_holders", "top10_floatholders", "stk_holdernumber", "stk_holdertrade", "pledge_stat", "pledge_detail", "share_float", "repurchase"]
        },
        "allowed_source_groups": ["announcements"],
        "priority": ["cninfo_disclosure", "sse_announcements", "szse_announcements", "eastmoney_notices"],
        "critical_use": "official_required",
        "notes": "Use periodic reports and official announcements for shareholder, pledge, reduction, and repurchase facts."
      },
      {
        "id": "investor_qa_gap",
        "match": {
          "section": "events",
          "api_names": ["irm_qa_sz", "irm_qa_sh"]
        },
        "allowed_source_groups": ["investor_relations_qa"],
        "priority": ["cninfo_irm", "sse_einteractive"],
        "critical_use": "auxiliary_only",
        "notes": "Investor Q&A is management communication and must not override formal filings."
      },
      {
        "id": "policy_gap",
        "match": {
          "section": "macro",
          "api_names": ["npr"]
        },
        "allowed_source_groups": ["policy"],
        "priority": ["gov_cn", "csrc", "ndrc", "miit", "pbc_interest_rates"],
        "critical_use": "official_required",
        "notes": "Policy facts must come from official government or regulator domains."
      },
      {
        "id": "news_gap",
        "match": {
          "section": "events",
          "api_names": ["news", "major_news", "cctv_news"]
        },
        "allowed_source_groups": ["finance_news", "policy"],
        "priority": ["eastmoney_kuaixun", "cls", "sina_finance", "gov_cn"],
        "critical_use": "auxiliary_only",
        "notes": "News is for event discovery; verify material company facts against announcements."
      },
      {
        "id": "research_report_gap",
        "match": {
          "section": "fundamentals",
          "api_names": ["research_report", "report_rc"]
        },
        "allowed_source_groups": ["research_reports"],
        "priority": ["eastmoney_reports"],
        "critical_use": "auxiliary_only",
        "notes": "Research reports can describe expectations and disagreements but cannot be treated as factual verification."
      }
    ]
  },
  "search_rules": {
    "allowed_when": [
      "project data is unavailable",
      "preferred Tushare interface is blocked or unavailable",
      "external_source_groups explicitly include a source for the data type"
    ],
    "query_requirements": [
      "Prefer site-restricted queries using the domains listed in external_source_groups.",
      "Record source id, URL, query time, and data date.",
      "Do not use generic search results for price, valuation, financial statements, macro data, or official announcements when an official source exists.",
      "If allowed sources do not provide reliable data, mark the field as 暂无可靠数据."
    ],
    "non_official_limits": [
      "Non-official sources may identify event leads or cross-check public datasets.",
      "Non-official sources cannot be the sole basis for regulatory, audited financial, or macro policy conclusions."
    ]
  }
}
