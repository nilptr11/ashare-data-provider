      },
      "rt_fut_min": {
        "reason": "requires separate permission and out of A-share MVP scope",
        "replacement_source_groups": ["out_of_scope"]
      },
      "ft_mins": {
        "reason": "requires separate permission and out of A-share MVP scope",
        "replacement_source_groups": ["out_of_scope"]
      },
      "hk_daily": {
        "reason": "requires separate permission and out of A-share MVP scope",
        "replacement_source_groups": ["out_of_scope"]
      },
      "rt_hk_k": {
        "reason": "requires separate permission and out of A-share MVP scope",
        "replacement_source_groups": ["out_of_scope"]
      },
      "hk_income": {
        "reason": "requires separate permission and out of A-share MVP scope",
        "replacement_source_groups": ["out_of_scope"]
      },
      "hk_balancesheet": {
        "reason": "requires separate permission and out of A-share MVP scope",
        "replacement_source_groups": ["out_of_scope"]
      },
      "hk_cashflow": {
        "reason": "requires separate permission and out of A-share MVP scope",
        "replacement_source_groups": ["out_of_scope"]
      },
      "hk_fina_indicator": {
        "reason": "requires separate permission and out of A-share MVP scope",
